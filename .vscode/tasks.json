{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "Debug"],
      "problemMatcher": []
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "Debug"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"],
      "dependsOn": ["CMake Configure (Debug)"]
    },
    {
      "label": "Clean (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "Debug", "--target", "clean"],
      "problemMatcher": []
    },
    {
      "label": "CMake Configure (ScreenKey Demo)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "ScreenKeyDemo"],
      "problemMatcher": []
    },
    {
      "label": "Build (ScreenKey Demo)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "ScreenKeyDemo"],
      "problemMatcher": ["$gcc"],
      "dependsOn": ["CMake Configure (ScreenKey Demo)"]
    }
  ]
}
